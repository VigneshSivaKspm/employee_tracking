{
  "expo": {
    "name": "WorkForce",
    "slug": "employee-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.worktrack.attendance",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WorkForce uses your location to verify office presence for attendance.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "WorkForce uses your location in the background for attendance tracking.",
        "NSMicrophoneUsageDescription": "WorkForce may access the microphone for enterprise compliance features.",
        "NSFaceIDUsageDescription": "WorkForce uses Face ID / Touch ID for secure authentication."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.worktrack.attendance",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withGradleFix",
      "expo-location",
      "expo-local-authentication",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "owner": "vigneshsivakspm",
    "extra": {
      "eas": {
        "projectId": "4e3e0403-1c00-42a8-a86a-01fe3aaa42c2"
      }
    }
  }
}
